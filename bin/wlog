#! /bin/bash

############################################################
######         ********* Work Log **********          ######
############################################################
##  - Manage your daily todos in a nice markdown format
##  - Generate a report for [slack|stand]ups
############################################################

ACTION="view"
IS_MAC=false
[[ "$OSTYPE" == "darwin"* ]] && IS_MAC=true

function _date_parse {
  # Parse a date string to YYYY-MM-DD
  if $IS_MAC; then date -jf "%Y-%m-%d" "$1" +%Y-%m-%d
  else date -d "$1" +%Y-%m-%d; fi
}
function _date_epoch {
  if $IS_MAC; then date -jf "%Y-%m-%d" "$1" +%s
  else date -d "$1" +%s; fi
}
function _date_next {
  if $IS_MAC; then date -j -v+1d -f "%Y-%m-%d" "$1" +%Y-%m-%d
  else date -d "$1 + 1 day" +%Y-%m-%d; fi
}
function _date_fmt {
  if $IS_MAC; then date -jf "%Y-%m-%d" "$1" "$2"
  else date --date="$1" "$2"; fi
}
## Options
##----------------------------------------------------------
while [[ $# -gt 0 ]] ; do
  key="$1"
  case $key in
##     -e | --edit
##        Edit your worklog
    -e | --edit)
      ACTION='edit'
      ;;
##     -E | --edit-script
##        Edit this script
    -E | --edit-script)
      ACTION='edit_script'
      ;;
##     -y | --yesterday
##        Edit your worklog
    -y | --yesterday)
      YESTERDAY=1
      ;;
##     -dS | --date-start
##        Add new todo item
    -dS | --date-start)
      date_start=`_date_parse "$2"`
      ;;
##     -a | --add
##        Add new todo item
    -a | --add)
      ACTION='add'
      while [[ ! -z "$2" ]]; do
        task_to_add="$task_to_add $2"
        shift
      done
      ;;
##     -s | --snippet
##        Add a new snippet
    -s | --snippet)
      ACTION='snippet'
      snippet_name='snippet'
      while [[ ! -z "$2" ]]; do
        snippet_name="$snippet_name $2"
        shift
      done
      ;;
##     -r | --report
##        generate a report for the last 2 days
    -r | --report)
      ACTION='report'
      ;;
##     -S | --summary
##        detailed summary
    -S | --summary)
      ACTION='summary'
      ;;
##     -D | --done
##        Mark a todo item as done by number
    -D | --done)
      ACTION='done_item'
      item_num="$2"
      shift
      ;;
##     -u | --undone
##        Mark a todo item as undone by number
    -u | --undone)
      ACTION='undone_item'
      item_num="$2"
      shift
      ;;
##     -U | --upgrade
##        Upgrade wlog files. backup recommended
    -U | --upgrade)
      ACTION='upgrade_old_wlogs'
      ;;
##
##     -h | --help
##        Display this help message
    -h | --help)
      grep -E --color '^#[#-]+' $0
      exit 1
      break
      ;;
    *)
   esac
   shift # past argument or value
done
##
##----------------------------------------------------------
## Environment Variables
##----------------------------------------------------------
##
## WLOG_HOME
##   Directory for all the wlogs.
##   defaults to $HOME/.wlog
if [ -z $WLOG_HOME ]; then
  WLOG_HOME="$HOME/.wlog"
fi

if [ -z $EDITOR ]; then
  EDITOR=vim
fi

function ensure_today {
  today_dir=`today_dir`
  today_todo="$today_dir/00-todo.md"

  if [ ! -d $today_dir ]; then
    mkdir -p $today_dir
    echo "## To Do" > $today_todo
    echo >> $today_todo
    yesterday=`yesterday`
    if [ -f $yesterday ]; then
      echo "Looks like its a new day!"
      echo -n "Would you like to edit $yesterday before we copy unfinished items to today? [Yn]"
      read confirm

      if [ -z $confirm ]; then
        confirm='y'
      fi

      [[ "$confirm" =~ ^(Y|y)$ ]] && $EDITOR $yesterday
      cat $yesterday | grep -E '^\- \[' | grep -v '\[X\]' >> $today_todo
    fi
  fi
}

function today_dir {
  echo "$WLOG_HOME/`date +%Y-%m-%d`"
}

function yesterday {
  yesterday=`find $WLOG_HOME -maxdepth 1 -mindepth 1 -type d | grep -Ev '(\.git|assets)' | sort | tail -n 2 | head -n 1`
  if [ "$yesterday" != "$today_dir" ]; then
    echo $yesterday/00-todo.md
  fi
}

function report_file {
  echo "#" `_date_fmt "$(basename $(dirname $1))" +'%A %B %d, %Y'`
  cat $1
  echo
  echo ------------------
  echo
}

function ensure_setup {
  if [ ! -d $WLOG_HOME ]; then
    echo -n "$WLOG_HOME doesn't exist. Should I create it? [Yn]"
    read confirm

    if [ -z $confirm ]; then
      confirm='y'
    fi

    [[ ! "$confirm" =~ ^(Y|y)$ ]] && exit
    mkdir $WLOG_HOME
  fi

  # ensure today has been created
  ensure_today
}

function view {
  echo "#" `_date_fmt "$(basename $(dirname $today_todo))" +'%A %B %d, %Y'`
  awk '/^\- \[/ { n++; printf "%2d. %s\n", n, $0; next } { print }' $today_todo
  echo
  echo ------------------
  echo
}

function edit {
  $EDITOR $today_todo
}

function edit_script {
  $EDITOR `which $0`
}

function add {
  echo "- [ ]$task_to_add" >> $today_todo
  view
}

function _mark_item {
  local pattern="$1"
  local replacement="$2"
  if [ -z "$item_num" ]; then
    echo "Usage: wlog --done/--undone <number>"
    exit 1
  fi
  line_num=$(awk '/^\- \[/ { n++ } n=='"$item_num"' { print NR; exit }' $today_todo)
  if [ -z "$line_num" ]; then
    echo "Item $item_num not found"
    exit 1
  fi
  if $IS_MAC; then
    sed -i '' "${line_num}s/${pattern}/${replacement}/" $today_todo
  else
    sed -i "${line_num}s/${pattern}/${replacement}/" $today_todo
  fi
  view
}

function done_item {
  _mark_item '- \[ \]' '- [X]'
}

function undone_item {
  _mark_item '- \[X\]' '- [ ]'
}

function snippet {
  $EDITOR "$today_dir/$snippet_name.md"
}

function report {
  today_s=$(date +%s)

  if [ ! -z $date_start ]; then
    while true; do
      date_s=$(_date_epoch "$date_start")
      if [ $today_s -le $date_s ]; then
        break
      fi

      if [ -d "$WLOG_HOME/$date_start" ]; then
        [ -f  "$WLOG_HOME/$date_start/"00-todo.md ] && report_file "$WLOG_HOME/$date_start/"00-todo.md
      fi
      date_start=`_date_next "$date_start"`
    done
  else
    yesterday=`yesterday`
    [ ! -x $yesterday ] && [ -f $yesterday ] && report_file $yesterday
  fi

  report_file $today_todo
}

function summary {
  today_s=$(date +%s)

  if [ ! -z $date_start ]; then
    while true; do
      date_s=$(_date_epoch "$date_start")
      if [ $today_s -le $date_s ]; then
        break
      fi

      if [ -d "$WLOG_HOME/$date_start" ]; then
        echo
        echo "# $date_start"
        cat "$WLOG_HOME/$date_start/"*.md
        echo ----------

      fi
      date_start=`_date_next "$date_start"`
    done
  else
    echo "# $date_start"
    cat "$today_dir/"*.md
  fi
}

function print_config {
  echo WLOG_HOME $WLOG_HOME;
}

function upgrade_old_wlogs {
  cd $WLOG_HOME
  echo [+] Attempting Upgrades
  ls 201*.md 2>&1 > /dev/null
  if [ $? -eq 0 ]; then
    echo [+] Moving old posts to dirs
    ls 201*.md | while read file; do dir=$(echo $file | cut -d. -f1); mkdir $dir; mv $file $dir/todo.md;  done
    echo [+] done
  fi
  ls */todo.md 2>&1 > /dev/null
  if [ $? -eq 0 ]; then
    echo [+] Moving todo.md to 00-todo.md
    ls */todo.md | while read file; do new_file=$(echo $file | sed 's/todo\.md/00-todo.md/'); mv $file $new_file;  done
    echo [+] done
  fi
}

ensure_setup
type "$ACTION" 1>/dev/null || exit 1

$ACTION
# the end
##
############################################################
# vim: set expandtab shiftwidth=2 softabstop=2
